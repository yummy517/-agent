# ============================================================
# .env 配置模板 - 复制为 .env 并填写真实值
# ============================================================

# ── LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
PRIMARY_MODEL=gpt-4o
FALLBACK_MODEL=gpt-4o-mini

# ── LangSmith 监控 ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=biomarker-multi-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your-redis-password

# ── 知识库 ─────────────────────────────────────────────────
VECTOR_STORE_PATH=./data/vectorstore
EMBEDDING_MODEL=text-embedding-3-small

# ── MCP PPT 服务 ───────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8001
MCP_PPT_TOOL_NAME=create_ppt
PPT_OUTPUT_DIR=./output/ppt

# ── 搜索 ───────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── 流程控制 ───────────────────────────────────────────────
MAX_TOTAL_ITERATIONS=3
MAX_REVIEW_RETRIES=3
REVIEW_PASS_THRESHOLD=0.75

# ── 日志 ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/agent.log

# ── FastAPI ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
